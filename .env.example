# === Required ===
BOT_TOKEN=123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11
OWNER_ID=123456789

# === Access Control (comma-separated) ===
ALLOWED_USERS=123456789,987654321
ALLOWED_GROUPS=-1001234567890,-1009876543210

# === Bot Behaviour ===
TEMP_DIR=/tmp/bun-video-bot
MAX_FILE_SIZE_MB=50
LOG_LEVEL=info

# === Proxy Configuration ===
# Manual proxy URL (takes priority over auto-pool). Supports http://, https://, socks5://
# Leave empty to use the auto-discovered free proxy pool with Tor fallback
# PROXY_URL=socks5://127.0.0.1:9050

# Enable the free proxy auto-pool (fetches from iplocate/free-proxy-list)
PROXY_ENABLED=true

# Enable Tor fallback when no proxies are available (requires tor package)
TOR_ENABLED=true

# === Storage ===
DATABASE_PATH=./data/bot.db
NODE_ENV=development
