# =============================================================================
# Hermes Video Bot — Environment template for Docker
# =============================================================================
# Copy to .env and fill in your values before running `docker compose up`
# =============================================================================

# Required
BOT_TOKEN=
OWNER_ID=

# Access control (comma-separated)
ALLOWED_USERS=
ALLOWED_GROUPS=

# Optional overrides
MAX_FILE_SIZE_MB=50
LOG_LEVEL=info
