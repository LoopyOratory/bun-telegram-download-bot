# =============================================================================
# Hermes Video Bot — Environment template for Docker
# =============================================================================
# Copy to .env and fill in your values before running `docker compose up`
# =============================================================================

# Required
BOT_TOKEN=
OWNER_ID=

# Access control (comma-separated)
ALLOWED_USERS=
ALLOWED_GROUPS=

# Proxy (optional — leave empty to use auto-pool with Tor fallback)
# PROXY_URL=socks5://127.0.0.1:9050
PROXY_ENABLED=true
TOR_ENABLED=true

# Optional overrides
MAX_FILE_SIZE_MB=50
LOG_LEVEL=info
